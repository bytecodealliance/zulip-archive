    {
        "content": "<p>fitzgen created <a href=\"https://github.com/bytecodealliance/wasmtime/pull/12923#discussion_r3022751909\">PR review comment</a>:</p>\n<blockquote>\n<p><code>u32::try_from(...).unwrap()</code></p>\n</blockquote>",
        "id": 583097881,
