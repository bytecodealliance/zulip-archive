    {
        "content": "<p>alexcrichton created <a href=\"https://github.com/bytecodealliance/wasmtime/pull/12712#discussion_r2880915335\">PR review comment</a>:</p>\n<blockquote>\n<p>Similar concern to above</p>\n</blockquote>",
