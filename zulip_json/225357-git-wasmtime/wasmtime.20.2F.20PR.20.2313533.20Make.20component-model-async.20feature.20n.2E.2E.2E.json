    {
        "content": "<p><span aria-label=\"thumbs up\" class=\"emoji emoji-1f44d\" role=\"img\" title=\"thumbs up\">:thumbs_up:</span> fitzgen submitted <a href=\"https://github.com/bytecodealliance/wasmtime/pull/13533#pullrequestreview-4412949872\">PR review</a>.</p>",
        "id": 599598802,
        "sender_full_name": "Wasmtime GitHub notifications bot",
        "timestamp": 1780428358
    },
    {
        "content": "<p><span aria-label=\"speech balloon\" class=\"emoji emoji-1f4ac\" role=\"img\" title=\"speech balloon\">:speech_balloon:</span> fitzgen created <a href=\"https://github.com/bytecodealliance/wasmtime/pull/13533#discussion_r3343856365\">PR review comment</a>:</p>\n<blockquote>\n<p>Maybe this should return a <code>Result&lt;TryMutexGuard&gt;</code> and <code>bail_bug!</code> on contention?</p>\n</blockquote>",
