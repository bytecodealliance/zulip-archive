    {
        "content": "<p><span aria-label=\"memo\" class=\"emoji emoji-1f4dd\" role=\"img\" title=\"memo\">:memo:</span> avanhatt submitted <a href=\"https://github.com/bytecodealliance/wasmtime/pull/13550#pullrequestreview-4432585164\">PR review</a>.</p>",
