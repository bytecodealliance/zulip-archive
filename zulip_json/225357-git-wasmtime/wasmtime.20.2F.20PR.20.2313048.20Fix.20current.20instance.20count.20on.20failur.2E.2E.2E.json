        "content": "<p>alexcrichton submitted <a href=\"https://github.com/bytecodealliance/wasmtime/pull/13048#pullrequestreview-4099420064\">PR review</a>.</p>",
        "id": 585204661,
        "sender_full_name": "Wasmtime GitHub notifications bot",
