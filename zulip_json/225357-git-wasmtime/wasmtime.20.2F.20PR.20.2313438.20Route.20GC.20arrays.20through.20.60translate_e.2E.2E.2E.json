        "content": "<p><span aria-label=\"memo\" class=\"emoji emoji-1f4dd\" role=\"img\" title=\"memo\">:memo:</span> fitzgen submitted <a href=\"https://github.com/bytecodealliance/wasmtime/pull/13438#pullrequestreview-4340106320\">PR review</a>.</p>",
        "id": 596835021,
        "sender_full_name": "Wasmtime GitHub notifications bot",
        "timestamp": 1779392570
