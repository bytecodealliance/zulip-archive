    {
        "content": "<p>fitzgen assigned fitzgen to <a href=\"https://github.com/bytecodealliance/wasmtime/issues/13538\">issue #13538</a>.</p>",
        "id": 599604361,
        "sender_full_name": "Wasmtime GitHub notifications bot",
